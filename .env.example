# Copy to .env and fill in the bits you care about.

# ---- Backends ----------------------------------------------------------------

# Primary: a local ComfyUI server.
# Default host:port matches ComfyUI Desktop. Leave as-is unless you've changed it.
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
# Optional: path to a UI-format workflow JSON. Empty = use the bundled
# BespokeAI-3D image-to-3D workflow.
COMFYUI_WORKFLOW=

# Fallback: BespokeAI API. Same key the ComfyUI node uses.
# Leave BESPOKE_API_URL empty unless you have a self-hosted endpoint; the default
# points at the production Supabase function CARMELA's BespokeAI backend uses.
BESPOKE_API_KEY=
BESPOKE_API_URL=

# Optional local TRELLIS.2 (24GB+ VRAM, Linux/WSL).
TRELLIS2_REPO=
TRELLIS2_CKPT=microsoft/TRELLIS.2-4B

# ---- CARLA -------------------------------------------------------------------

CARLA_HOST=localhost
CARLA_PORT=2000
CARLA_ROOT=C:/Users/allas/CARLA_0.9.16

# ---- Library -----------------------------------------------------------------

ASSET_LIBRARY_DIR=./assets/library
ASSET_CACHE_DIR=./assets/cache
